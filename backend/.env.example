# =========================
# InsightAgentUltra 后端环境变量模板
# 不要把真实密钥提交到仓库
# =========================

# 项目基础配置
PROJECT_NAME=InsightAgentUltra API
WORKSPACE_ROOT=/absolute/path/to/InsightAgentUltra

# 本地基础模型（默认用于轻量直连对话）
BASIC_MODEL_PROVIDER=ollama
BASIC_MODEL_BASE_URL=http://127.0.0.1:11434
BASIC_MODEL_NAME=qwen3.5:9b
BASIC_MODEL_API_KEY=EMPTY

# 兼容旧配置名（可选）
OLLAMA_BASE_URL=
LLM_MODEL=

# DeepSeek（当前代码启动时会初始化）
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-reasoner
DEEPSEEK_CHAT_MODEL=deepseek-chat

# MiniMax（可选）
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.5

# Xiaomi MiMo（可选）
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2-flash
MIMO_PRO_MODEL=mimo-v2-pro

# 检索 / 向量库
VECTOR_STORE_PATH=/absolute/path/to/InsightAgentUltra/backend/data/chroma_db
PARENT_STORE_PATH=/absolute/path/to/InsightAgentUltra/backend/data/parent_store
EMBEDDING_MODEL=shibing624/text2vec-base-chinese
EMBEDDING_DEVICE=auto
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_DEVICE=auto

# ReAct / PAE / 上下文压缩
REACT_MAX_TOOL_CALLS=10
REACT_MAX_NO_PROGRESS_CALLS=3
PAE_MAX_CALLS_PER_REQUEST=1
CONTEXT_COMPRESSION_ENABLED=true
CONTEXT_COMPRESSION_MAX_MESSAGES=14
CONTEXT_COMPRESSION_MAX_CHARS=12000
CONTEXT_COMPRESSION_RECENT_TURNS=4
CONTEXT_COMPRESSION_MIN_DELTA_MESSAGES=4

# MCP / Skill
MCP_ENABLED=true
MCP_CONFIG_PATH=
SKILL_COMPAT_MODE=claude

# PostgreSQL（必填：历史会话、长期记忆、checkpoint 都依赖）
POSTGRES_URL=postgresql://username:password@127.0.0.1:5432/insightagent
